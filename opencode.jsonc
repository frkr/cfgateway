{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "share": "disabled",
  "instructions": [
    "AGENTS.md"
  ],
  "model": "opencode/grok-code",
  "small_model": "opencode/grok-code",
  "tools": {
    "todowrite": true,
    "todoread": true,
    "webfetch": true
  },
  "permission": {
    "external_directory": "deny",
    "doom_loop": "deny"
  },
  "mcp": {
    "mcp_DOCKER": {
      "enabled": true,
      "type": "local",
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run"
      ]
    }
  }
}